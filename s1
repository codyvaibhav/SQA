How to Combine Multiple Model Data (For Option A)
Add this to your VBA — it auto-combines all model sheets into one master sheet before refreshing:

vba
Sub CombineAndRefresh()
    Dim masterSheet As Worksheet
    Dim modelSheet As Worksheet
    Dim lastRow As Long
    Dim masterLastRow As Long
    
    ' Clear old combined data
    Set masterSheet = ThisWorkbook.Sheets("Combined_Data")
    masterSheet.Rows("2:" & masterSheet.Rows.Count).ClearContents
    masterLastRow = 2
    
    ' Loop through each model sheet and copy data
    Dim modelNames As Variant
    modelNames = Array("Raw_ModelA", "Raw_ModelB", "Raw_ModelC") ' add your sheet names
    
    Dim i As Integer
    For i = 0 To UBound(modelNames)
        Set modelSheet = ThisWorkbook.Sheets(modelNames(i))
        lastRow = modelSheet.Cells(modelSheet.Rows.Count, 1).End(xlUp).Row
        
        If lastRow > 1 Then  ' If sheet has data beyond header
            modelSheet.Range("A2:Z" & lastRow).Copy
            masterSheet.Cells(masterLastRow, 1).PasteSpecial xlPasteValues
            masterLastRow = masterSheet.Cells(masterSheet.Rows.Count, 1).End(xlUp).Row + 1
        End If
    Next i
    
    Application.CutCopyMode = False
    ThisWorkbook.RefreshAll
    MsgBox "All models refreshed! ✓", vbInformation
End Sub
