' AUTO-RUNS when file is opened
Private Sub Workbook_Open()
    Call RefreshDashboard
End Sub

' AUTO-RUNS when any sheet is changed
Private Sub Workbook_SheetChange(ByVal Sh As Object, ByVal Target As Range)
    ' Only refresh if data sheet was changed
    If Sh.Name = "Raw_Data" Then
        Call RefreshDashboard
    End If
End Sub

' THE MAIN REFRESH FUNCTION
Sub RefreshDashboard()
    Application.ScreenUpdating = False  ' Stops screen flickering
    
    ThisWorkbook.RefreshAll             ' Refreshes ALL pivot tables at once
    
    Application.Calculate               ' Recalculates all formulas
    Application.ScreenUpdating = True
    
    MsgBox "Dashboard refreshed! ✓", vbInformation  ' Optional confirmation
End Sub
