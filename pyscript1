    df2["Day"] = range(1, len(df2) + 1)
    df2["S26U_O_Ratio"] = round(df2["S26U_O_Acc. Service"] / df2["S26U_O_Sell Out"], 5)
    df2["S25U_O_Ratio"] = round(df2["S25U_O_Acc. Service"] / df2["S25U_O_Sell Out"], 5)
