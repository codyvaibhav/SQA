@st.cache_data
def get_asrdata():
    df2 = pd.read_excel(asrdata_path, skiprows=9)
    df2.columns = df2.columns.str.replace('\n', ' ')
    df2.columns = ["Days", "S26U_O_Acc. Service", "S26U_O_Sell Out", "S25U_O_Acc. Service", "S25U_O_Sell Out"]
