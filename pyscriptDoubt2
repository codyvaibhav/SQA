# If you did this:
df["Service Date"] = df["Service Date"].dt.date  # ← now it's date objects, not Timestamps

# Then this comparison breaks silently:
start_date_ts = pd.Timestamp(st.session_state.start_date_input)  # Timestamp
dfSelection = df[df["Service Date"] >= start_date_ts]  # comparing date vs Timestamp ❌

# Keep datetime for filtering
df["Service Date"] = pd.to_datetime(df["Service Date"].astype(str).str.zfill(6), format='%y%m%d', errors='coerce')

# Separate display column
df["Svc Date"] = df["Service Date"].dt.strftime('%d/%m/%Y')

# --- Session state init ---
if 'start_date_input' not in st.session_state:
    st.session_state.start_date_input = df["Service Date"].min().date()
if 'end_date_input' not in st.session_state:
    st.session_state.end_date_input = df["Service Date"].max().date()

# --- Reset button (anywhere) ---
if st.button("Reset Dates"):
    st.session_state.start_date_input = df["Service Date"].min().date()
    st.session_state.end_date_input = df["Service Date"].max().date()
    st.rerun()

# --- Date inputs ---
col1, col2, *_ = st.columns([1, 1, 1, 3])
with col1:
    st.date_input("Start Date", key='start_date_input')
with col2:
    st.date_input("End Date", key='end_date_input')

# --- Filter using Timestamps ---
start_date_ts = pd.Timestamp(st.session_state.start_date_input)
end_date_ts = pd.Timestamp(st.session_state.end_date_input)

dfSelection = df[
    (df["Service Date"] >= start_date_ts) &
    (df["Service Date"] <= end_date_ts)
]

# --- Display with formatted date ---
st.dataframe(
    dfSelection,
    column_config={
        "Service Date": st.column_config.DateColumn("Service Date", format="DD/MM/YYYY")
    }
)

# --- Reset button (anywhere) ---
if st.button("Reset Dates"):
    st.session_state.start_date_input = df["Service Date"].min().date()
    st.session_state.end_date_input = df["Service Date"].max().date()
    st.session_state.do_rerun = True

if st.session_state.get("do_rerun", False):
    st.session_state.do_rerun = False
    st.rerun()  # 👈 rerun happens OUTSIDE the button block

